              "defaultValue": 90,
              "minValue": 1,
              "maxValue": 100,
              "metadata": {
                "description": "DMARC pass rate percentage threshold. An alert fires when the pass rate drops below this value."
              }
            },
            "enabled": {
              "type": "bool",
              "defaultValue": true,
              "metadata": {
                "description": "Whether the alert rules are enabled."
              }
            }
          },
          "variables": {
            "alertEnabled": "[if(parameters('enabled'), 'true', 'false')]",
            "actionGroups": "[if(empty(parameters('actionGroupId')), createArray(), createArray(parameters('actionGroupId')))]"
          },
          "resources": [
            {
              "type": "Microsoft.Insights/scheduledQueryRules",
              "apiVersion": "2023-03-15-preview",
              "name": "dmarc-pass-rate-drop",
              "location": "[parameters('location')]",
              "properties": {
                "displayName": "DMARC Pass Rate Drop",
                "description": "[format('Triggers when the overall DMARC pass rate (at least SPF or DKIM passing) drops below {0}% over the last 24 hours. A sustained drop may indicate a misconfiguration, a new unauthorized sender, or an active spoofing campaign.', parameters('passRateThreshold'))]",
                "severity": 2,
                "enabled": "[equals(variables('alertEnabled'), 'true')]",
                "evaluationFrequency": "PT1H",
                "windowSize": "P1D",
                "scopes": [
                  "[parameters('workspaceId')]"
                ],
                "criteria": {
                  "allOf": [
                    {
                      "query": "DMARCReports_CL\n| extend MessageCountSafe = tolong(coalesce(MessageCount, 0))\n| summarize\n    TotalMessages = sum(MessageCountSafe),\n    PassedMessages = sumif(MessageCountSafe, PolicyEvaluated_dkim == \"pass\" or PolicyEvaluated_spf == \"pass\")\n| extend PassRate = iff(TotalMessages == 0, 100.0, round(toreal(PassedMessages) / toreal(TotalMessages) * 100, 2))\n| where PassRate < ${passRateThreshold}\n",
                      "timeAggregation": "Count",
                      "operator": "GreaterThan",
                      "threshold": 0,
                      "failingPeriods": {
                        "numberOfEvaluationPeriods": 1,
                        "minFailingPeriodsToAlert": 1
                      }
                    }
                  ]
                },
                "actions": {
                  "actionGroups": "[variables('actionGroups')]"
                },
                "autoMitigate": true
              }
            },
            {
              "type": "Microsoft.Insights/scheduledQueryRules",
              "apiVersion": "2023-03-15-preview",
              "name": "dmarc-no-reports-received",
              "location": "[parameters('location')]",
              "properties": {
                "displayName": "No DMARC Reports Received",
                "description": "Triggers when no DMARC reports have been ingested into the DMARCReports_CL table for 48 or more hours. This may indicate a problem with the mail flow, the Function App processing pipeline, or the data collection rule.",
                "severity": 1,
                "enabled": "[equals(variables('alertEnabled'), 'true')]",
                "evaluationFrequency": "P1D",
                "windowSize": "P2D",
                "scopes": [
                  "[parameters('workspaceId')]"
                ],
                "criteria": {
                  "allOf": [
                    {
                      "query": "DMARCReports_CL\n| summarize ReportCount = count()\n| where ReportCount == 0\n",
                      "timeAggregation": "Count",
                      "operator": "GreaterThan",
                      "threshold": 0,
                      "failingPeriods": {
                        "numberOfEvaluationPeriods": 1,
                        "minFailingPeriodsToAlert": 1
                      }
                    }
                  ]
                },
                "actions": {
                  "actionGroups": "[variables('actionGroups')]"
                },
                "autoMitigate": true
              }
            },
            {
              "type": "Microsoft.Insights/scheduledQueryRules",
              "apiVersion": "2023-03-15-preview",
              "name": "dmarc-new-source-ip-high-failure",
              "location": "[parameters('location')]",
              "properties": {
                "displayName": "New Source IP with High Failure Rate",
                "description": "Triggers when a source IP address not seen in the previous 30 days appears with both SPF and DKIM failing and at least 10 failed messages. This pattern often indicates a new unauthorized sender or spoofing attempt targeting your domain.",
                "severity": 2,
                "enabled": "[equals(variables('alertEnabled'), 'true')]",
                "evaluationFrequency": "PT6H",
                "windowSize": "P1D",
                "scopes": [
                  "[parameters('workspaceId')]"
                ],
                "criteria": {
                  "allOf": [
                    {
                      "query": "let lookbackStart = ago(31d);\nlet lookbackEnd = ago(1d);\nlet knownIPs = DMARCReports_CL\n    | where TimeGenerated between (lookbackStart .. lookbackEnd)\n    | distinct SourceIP;\nDMARCReports_CL\n| where TimeGenerated >= ago(1d)\n| where PolicyEvaluated_dkim != \"pass\" and PolicyEvaluated_spf != \"pass\"\n| where SourceIP !in (knownIPs)\n| summarize FailedMessages = sum(MessageCount) by SourceIP, Domain\n| where FailedMessages >= 10\n",
                      "timeAggregation": "Count",
                      "operator": "GreaterThan",
                      "threshold": 0,
                      "failingPeriods": {
                        "numberOfEvaluationPeriods": 1,
                        "minFailingPeriodsToAlert": 1
                      }
                    }
                  ]
                },
                "actions": {
                  "actionGroups": "[variables('actionGroups')]"
                },
                "autoMitigate": true
              }
            },
            {
              "type": "Microsoft.Insights/scheduledQueryRules",
              "apiVersion": "2023-03-15-preview",
              "name": "dmarc-volume-spike",
              "location": "[parameters('location')]",
              "properties": {
                "displayName": "DMARC Sudden Volume Spike",
                "description": "Triggers when the daily DMARC report message volume exceeds 3x the average daily volume over the previous 30 days. A sudden spike may indicate a large-scale spoofing campaign, a mail loop, or an unexpected configuration change.",
                "severity": 3,
                "enabled": "[equals(variables('alertEnabled'), 'true')]",
                "evaluationFrequency": "PT1H",
                "windowSize": "P1D",
                "scopes": [
                  "[parameters('workspaceId')]"
                ],
                "criteria": {
                  "allOf": [
                    {
                      "query": "let baselineStart = ago(31d);\nlet baselineEnd = ago(1d);\nlet baseline = DMARCReports_CL\n    | where TimeGenerated between (baselineStart .. baselineEnd)\n    | extend MessageCountSafe = tolong(coalesce(MessageCount, 0))\n    | summarize DailyVolume = sum(MessageCountSafe) by bin(TimeGenerated, 1d)\n    | summarize AvgDailyVolume = avg(DailyVolume);\nlet todayVolume = DMARCReports_CL\n    | where TimeGenerated >= ago(1d)\n    | extend MessageCountSafe = tolong(coalesce(MessageCount, 0))\n    | summarize TodayVolume = sum(MessageCountSafe);\nbaseline\n| extend JoinKey = 1\n| join kind=inner (todayVolume | extend JoinKey = 1) on JoinKey\n| where TodayVolume > AvgDailyVolume * 3 and AvgDailyVolume > 0\n",
                      "timeAggregation": "Count",
                      "operator": "GreaterThan",
                      "threshold": 0,
                      "failingPeriods": {
                        "numberOfEvaluationPeriods": 1,
                        "minFailingPeriodsToAlert": 1
                      }
                    }
                  ]
                },
                "actions": {
                  "actionGroups": "[variables('actionGroups')]"
                },
                "autoMitigate": true
              }
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[variables('functionAppName')]"
    },
    "functionAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2024-04-01', 'full').identity.principalId]"
    },
    "functionAppDefaultHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2024-04-01').defaultHostName]"
    },
    "dcrEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName')), '2023-03-11').logsIngestion.endpoint]"
    },
    "dcrImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName')), '2023-03-11').immutableId]"
    },
    "dcrStreamName": {
      "type": "string",
      "value": "[variables('streamName')]"
    },
    "workspaceId": {
      "type": "string",
      "value": "[variables('workspaceId')]"
    },
